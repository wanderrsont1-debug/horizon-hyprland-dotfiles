[
    {
        "position": "top",
        "reload_style_on_change": true,
        "margin-top": 8,
        "modules-center": [
            "custom/arch",
            "clock",
            "hyprland/workspaces",
            "memory",
            "cpu",
            "group/hide-tray",
            "group/battery-drawer",
            "custom/notification",
            "group/updates-drawer"
        ],


/*        "group/mpris-drawer": {
            "orientation": "inherit",
            "drawer": {
                "transition-duration": "0.3",
                "children-class": "mpris-drawer",
                "click-to-reveal": false
            },
            "modules": ["custom/mpris-trigger", "mpris"]
        },*/

/*        "custom/mpris-trigger": {
            "format": "♪",
            "tooltip": false
        },*/

/*        "mpris": {
            "format": "{player_icon} {title}",
            "format-paused": "{status_icon} <i>{position} {artist}</i>",
            "format-stopped": "",
            "player-icons": {
                "default": "",
                "firefox": "",
                "mpv": "",
                "spotify": ""
            },
            "status-icons": {
                "paused": ""
            },
            "max-length": 20
