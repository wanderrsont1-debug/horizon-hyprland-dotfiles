    return 0
}

__dl_on_exit() {
    local _status=$?
    __dl_status_put final_exit_status "${_status}"
    [[ -n "${__DL_SIGNAL}" ]] && __dl_status_put signal "${__DL_SIGNAL}"

    if (( _status != 0 )) && (( __DL_TRAP_FIRED == 0 )); then
