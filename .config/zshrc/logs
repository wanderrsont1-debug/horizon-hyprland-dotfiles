            [[ "$source_sha256_before" != "$source_sha256_after" ]] && printf '  source_changed_during_run=true\n' >&2

            printf 'Artifacts stored at: %s%s%s\n' "$c_bold" "$session_dir" "$c_reset" >&2
            printf '  ├─ metadata.txt\n' >&2
            printf '  ├─ system_state.txt\n' >&2
            printf '  ├─ stdout.log\n' >&2
            printf '  ├─ stderr.log\n' >&2
            printf '  ├─ combined.log\n' >&2
            printf '  ├─ io_events.log\n' >&2
            printf '  ├─ child_events.log\n' >&2
            printf '  ├─ child_status.env\n' >&2
            printf '  ├─ child_set_o.log\n' >&2
            printf '  ├─ child_shopt.log\n' >&2
            printf '  ├─ child_traps.log\n' >&2
            [[ -s "$child_first_err_log" ]] && printf '  ├─ child_first_error.log\n' >&2
            [[ -s "$error_dump" ]] && printf '  ├─ error_state_dump.txt\n' >&2
            (( opt_xtrace )) && printf '  ├─ trace.log\n' >&2
            (( opt_strace )) && printf '  ├─ strace.*\n' >&2
            [[ -f "$resource_log" ]] && printf '  ├─ resource_usage.log\n' >&2
            [[ -f "$shellcheck_log" ]] && printf '  ├─ shellcheck_preflight.log\n' >&2
            [[ -f "$journal_log" ]] && printf '  ├─ systemd_journal.log\n' >&2
            (( had_lingering_descendants )) && printf '  ├─ lingering_processes.log\n' >&2
            (( surviving_lingering_descendants )) && printf '  ├─ lingering_survivors.log\n' >&2
            [[ -s "$drain_diag" ]] && printf '  └─ forced_drain_diagnostics.txt\n' >&2
        fi

        exit_code=$return_code
    } always {
        umask "$old_umask" 2>/dev/null || :

        (( timeout_pid > 0 )) && kill "$timeout_pid" 2>/dev/null || :
        (( collector_pid > 0 )) && kill "$collector_pid" 2>/dev/null || :
        (( child_pid > 0 )) && kill "$child_pid" 2>/dev/null || :

        [[ -n "$env_prelude" ]] && "$rm_bin" -f -- "$env_prelude" 2>/dev/null
        [[ -n "$launcher_path" ]] && "$rm_bin" -f -- "$launcher_path" 2>/dev/null
        [[ -n "$collector_path" ]] && "$rm_bin" -f -- "$collector_path" 2>/dev/null
        [[ -n "$fifo_out" ]] && "$rm_bin" -f -- "$fifo_out" 2>/dev/null
        [[ -n "$fifo_err" ]] && "$rm_bin" -f -- "$fifo_err" 2>/dev/null
        [[ -n "$timeout_flag" ]] && "$rm_bin" -f -- "$timeout_flag" 2>/dev/null
        [[ -n "$forced_out_flag" ]] && "$rm_bin" -f -- "$forced_out_flag" 2>/dev/null
        [[ -n "$forced_err_flag" ]] && "$rm_bin" -f -- "$forced_err_flag" 2>/dev/null
        [[ -n "$stdout_eof_flag" ]] && "$rm_bin" -f -- "$stdout_eof_flag" 2>/dev/null
        [[ -n "$stderr_eof_flag" ]] && "$rm_bin" -f -- "$stderr_eof_flag" 2>/dev/null

        unfunction __logs_is_bash_shebang 2>/dev/null || :
    }

    return "$exit_code"
}

sc() { logs "$@"; }
