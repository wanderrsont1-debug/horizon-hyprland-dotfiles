logs() {
    emulate -L zsh
    setopt localoptions localtraps pipefail no_nomatch no_multios
    unsetopt monitor aliases

    function __logs_is_bash_shebang() {
        emulate -L zsh

        local line="$1"
        [[ "$line" == '#!'* ]] || return 0

        line="${line#\#!}"
        line="${line%%$'\r'}"

        local -a words
        words=(${(z)line})
        (( $#words )) || return 1

        case "${words[1]:t}" in
            bash)
                return 0
                ;;
            env)
                local i
                for (( i = 2; i <= $#words; ++i )); do
                    case "${words[i]}" in
                        -*)  continue ;;
                        *=*) continue ;;
                        bash|*/bash) return 0 ;;
                        *) return 1 ;;
                    esac
                done
                return 1
                ;;
            *)
                return 1
                ;;
        esac
    }

    local -i opt_strace=0 opt_quiet=0 opt_strict=0 opt_journal=0 opt_xtrace=0 opt_shellcheck=0
    local opt_outdir="" opt_timeout=""

    local raw_target="" script_invoke_path="" script_real_path="" script_name="" safe_name="" script_dir=""
    local first_line="" j_cursor="" orig_bash_env=""
    local -a script_args=()

    local c_red="" c_yellow="" c_green="" c_blue="" c_bold="" c_reset=""
    if [[ -t 2 && "${TERM:-}" != "dumb" ]]; then
        c_red=$'\e[31m'
        c_yellow=$'\e[33m'
        c_green=$'\e[32m'
        c_blue=$'\e[34m'
        c_bold=$'\e[1m'
        c_reset=$'\e[0m'
    fi

    while (( $# )); do
        case "$1" in
            -h|--help)
                printf 'Usage: logs [options] <bash-script> [args...]\n'
                printf 'Bash-focused execution, tracing, and log capture wrapper.\n'
                printf '  -q, --quiet         Suppress live child stdout/stderr mirroring\n'
                printf '  -S, --strict        Enable child strict mode: set -euo pipefail\n'
                printf '  -x, --xtrace        Enable Bash xtrace into trace.log\n'
                printf '  -s, --strace        Capture strace (-ff -ttt -T -y -yy -s 1024)\n'
                printf '  -C, --shellcheck    Run shellcheck preflight on the snapshot\n'
                printf '  -j, --journal       Capture journalctl entries after the run\n'
                printf '  -t, --timeout DUR   Kill child process group after DUR, then after 5s force kill\n'
                printf '  -o, --outdir DIR    Write sessions under DIR\n'
                return 0
                ;;
            -q|--quiet)      opt_quiet=1; shift ;;
            -S|--strict)     opt_strict=1; shift ;;
            -x|--xtrace)     opt_xtrace=1; shift ;;
            -s|--strace)     opt_strace=1; shift ;;
            -C|--shellcheck) opt_shellcheck=1; shift ;;
            -j|--journal)    opt_journal=1; shift ;;
            -t|--timeout)
                if (( $# < 2 )); then
                    printf '%sError:%s -t requires a duration\n' "$c_red" "$c_reset" >&2
                    return 2
                fi
                if [[ ! "$2" =~ ^[0-9]+([.][0-9]+)?([smhd])?$ ]]; then
                    printf '%sError:%s invalid timeout: %s\n' "$c_red" "$c_reset" "$2" >&2
                    return 2
                fi
                opt_timeout="$2"
                shift 2
                ;;
            --timeout=*)
                opt_timeout="${1#*=}"
                if [[ -z "$opt_timeout" || ! "$opt_timeout" =~ ^[0-9]+([.][0-9]+)?([smhd])?$ ]]; then
                    printf '%sError:%s invalid timeout: %s\n' "$c_red" "$c_reset" "$opt_timeout" >&2
                    return 2
                fi
                shift
                ;;
            -o|--outdir)
                if (( $# < 2 )) || [[ -z "$2" ]]; then
                    printf '%sError:%s -o requires a non-empty directory\n' "$c_red" "$c_reset" >&2
                    return 2
                fi
                opt_outdir="$2"
                shift 2
                ;;
            --outdir=*)
                opt_outdir="${1#*=}"
                if [[ -z "$opt_outdir" ]]; then
                    printf '%sError:%s --outdir requires a directory\n' "$c_red" "$c_reset" >&2
                    return 2
                fi
                shift
                ;;
            --)
                shift
                break
                ;;
            -*)
                printf '%sError:%s unknown option: %s\n' "$c_red" "$c_reset" "$1" >&2
                return 2
                ;;
            *)
                break
                ;;
        esac
    done

    if (( $# == 0 )); then
        printf '%sError:%s no script provided\n' "$c_red" "$c_reset" >&2
        return 2
    fi

    raw_target="$1"
    shift
    script_args=("$@")

    local bash_bin="${commands[bash]-}"
    local env_bin="${commands[env]-}"
    local cp_bin="${commands[cp]-}"
    local mkdir_bin="${commands[mkdir]-}"
    local mktemp_bin="${commands[mktemp]-}"
    local mkfifo_bin="${commands[mkfifo]-}"
    local realpath_bin="${commands[realpath]-}"
    local date_bin="${commands[date]-}"
    local awk_bin="${commands[awk]-}"
    local grep_bin="${commands[grep]-}"
    local sed_bin="${commands[sed]-}"
    local perl_bin="${commands[perl]-}"
    local setsid_bin="${commands[setsid]-}"
    local ps_bin="${commands[ps]-}"
    local sort_bin="${commands[sort]-}"
    local rm_bin="${commands[rm]-}"
    local chmod_bin="${commands[chmod]-}"
    local cat_bin="${commands[cat]-}"
    local sleep_bin="${commands[sleep]-}"
    local ls_bin="${commands[ls]-}"

    local sha256sum_bin="${commands[sha256sum]-}"
    local git_bin="${commands[git]-}"
    local shellcheck_bin="${commands[shellcheck]-}"
    local strace_bin="${commands[strace]-}"
    local journalctl_bin="${commands[journalctl]-}"
    local lsof_bin="${commands[lsof]-}"
    local fuser_bin="${commands[fuser]-}"
    local hostname_bin="${commands[hostname]-}"
    local uptime_bin="${commands[uptime]-}"
    local free_bin="${commands[free]-}"
    local df_bin="${commands[df]-}"
    local lscpu_bin="${commands[lscpu]-}"

    local time_bin="/usr/bin/time"
    [[ -x "$time_bin" ]] || time_bin=""

    local _tool _var
    for _tool in bash env cp mkdir mktemp mkfifo realpath date awk grep sed perl setsid ps sort rm chmod cat sleep ls; do
        _var="${_tool}_bin"
        [[ -n "${(P)_var}" ]] || {
            printf '%sError:%s required command missing: %s\n' "$c_red" "$c_reset" "$_tool" >&2
            return 1
        }
    done

    if (( opt_strace )) && [[ -z "$strace_bin" ]]; then
        printf '%sError:%s --strace requested but strace is not installed\n' "$c_red" "$c_reset" >&2
        return 1
    fi

    if (( opt_journal )) && [[ -z "$journalctl_bin" ]]; then
        printf '%sError:%s --journal requested but journalctl is not installed\n' "$c_red" "$c_reset" >&2
        return 1
    fi

    if [[ "$raw_target" == */* || "$raw_target" == .* || -f "$raw_target" ]]; then
        script_invoke_path="$raw_target"
    elif [[ -f "./$raw_target" ]]; then
        script_invoke_path="./$raw_target"
    elif [[ -n "${commands[$raw_target]-}" ]]; then
        script_invoke_path="${commands[$raw_target]}"
    else
        printf '%sError:%s target not found: %s\n' "$c_red" "$c_reset" "$raw_target" >&2
        return 1
    fi

    script_real_path="$("$realpath_bin" -e -- "$script_invoke_path" 2>/dev/null)" || {
        printf '%sError:%s failed to resolve target path: %s\n' "$c_red" "$c_reset" "$script_invoke_path" >&2
        return 1
    }

    [[ -f "$script_real_path" && -r "$script_real_path" ]] || {
        printf '%sError:%s target is not a readable regular file: %s\n' "$c_red" "$c_reset" "$script_real_path" >&2
        return 1
    }

    IFS= read -r first_line < "$script_real_path" 2>/dev/null || first_line=""
    __logs_is_bash_shebang "$first_line" || {
        printf '%sError:%s target shebang is not Bash: %s\n' "$c_red" "$c_reset" "$first_line" >&2
        return 1
    }

    script_name="${script_real_path:t}"
    safe_name="${script_name//[^[:alnum:]._-]/_}"
    script_dir="${script_real_path:h}"

    local base="${opt_outdir:-${HOME:-$PWD}/Documents/logs/script_logs}"
    local outdir="$base"
    [[ "$outdir" != "/" ]] && outdir="${outdir%/}"

    local ts="$("$date_bin" '+%Y%m%d-%H%M%S' 2>/dev/null)"
    [[ -n "$ts" ]] || ts="unknown-time"

    local old_umask="$(umask)"

    local session_dir="" trace_log="" stdout_log="" stderr_log="" combined_log="" meta_log="" sys_log=""
    local journal_log="" error_dump="" snapshot_path="" env_prelude="" fifo_out="" fifo_err=""
    local syntax_log="" shellcheck_log="" resource_log="" strace_prefix="" io_events_log=""
    local child_events_log="" child_status_file="" child_set_o_log="" child_shopt_log="" child_traps_log=""
    local child_first_err_log="" child_info="" drain_diag="" lingering_log="" lingering_survivors_log=""
    local timeout_flag="" forced_out_flag="" forced_err_flag="" launcher_path="" collector_path=""
    local stdout_eof_flag="" stderr_eof_flag=""

    local source_sha256_before="unavailable" source_sha256_after="unavailable" snapshot_sha256="unavailable"
    local bash_version_line="" host_name="unknown" child_pgid="" verdict="SUCCESS" child_signal=""

    local -i child_pid=0 timeout_pid=0 collector_pid=0
    local -i exit_code=0 return_code=0 timed_out=0 had_lingering_descendants=0 surviving_lingering_descendants=0 forced_out=0 forced_err=0
    local -i child_prelude_loaded=0 child_err_seen=0 child_opt_errexit=0 child_opt_nounset=0
    local -i child_opt_pipefail=0 child_opt_xtrace=0 child_xtrace_active=0

    {
        umask 077

        if ! "$mkdir_bin" -p -- "$outdir"; then
            printf '%sError:%s failed to create output directory: %s\n' "$c_red" "$c_reset" "$outdir" >&2
            exit_code=1
            return 1
        fi

        session_dir="$("$mktemp_bin" -d -- "${outdir}/${safe_name}.${ts}.XXXXXXXX" 2>/dev/null)" || {
            printf '%sError:%s failed to create session directory under %s\n' "$c_red" "$c_reset" "$outdir" >&2
            exit_code=1
            return 1
        }

        trace_log="${session_dir}/trace.log"
        stdout_log="${session_dir}/stdout.log"
        stderr_log="${session_dir}/stderr.log"
        combined_log="${session_dir}/combined.log"
        meta_log="${session_dir}/metadata.txt"
        sys_log="${session_dir}/system_state.txt"
        journal_log="${session_dir}/systemd_journal.log"
        error_dump="${session_dir}/error_state_dump.txt"
        snapshot_path="${session_dir}/script_snapshot.source"
        env_prelude="${session_dir}/.bash_prelude.sh"
        fifo_out="${session_dir}/fifo_out"
        fifo_err="${session_dir}/fifo_err"
        syntax_log="${session_dir}/syntax_preflight.log"
        shellcheck_log="${session_dir}/shellcheck_preflight.log"
        resource_log="${session_dir}/resource_usage.log"
        strace_prefix="${session_dir}/strace"
        io_events_log="${session_dir}/io_events.log"

        child_events_log="${session_dir}/child_events.log"
        child_status_file="${session_dir}/child_status.env"
        child_set_o_log="${session_dir}/child_set_o.log"
        child_shopt_log="${session_dir}/child_shopt.log"
        child_traps_log="${session_dir}/child_traps.log"
        child_first_err_log="${session_dir}/child_first_error.log"
        child_info="${session_dir}/child_process.txt"
        drain_diag="${session_dir}/forced_drain_diagnostics.txt"
        lingering_log="${session_dir}/lingering_processes.log"
        lingering_survivors_log="${session_dir}/lingering_survivors.log"
        timeout_flag="${session_dir}/.timed_out"
        forced_out_flag="${session_dir}/.forced_stdout"
        forced_err_flag="${session_dir}/.forced_stderr"
        stdout_eof_flag="${session_dir}/.stdout_eof"
        stderr_eof_flag="${session_dir}/.stderr_eof"
        launcher_path="${session_dir}/.launcher.sh"
        collector_path="${session_dir}/.collector.pl"

        local f=""
        for f in \
            "$stdout_log" "$stderr_log" "$combined_log" "$meta_log" "$sys_log" "$syntax_log" "$io_events_log" \
            "$child_events_log" "$child_status_file" "$child_set_o_log" "$child_shopt_log" \
            "$child_traps_log" "$child_first_err_log" "$child_info" "$drain_diag" \
            "$lingering_log" "$lingering_survivors_log" "$error_dump"
        do
            : >| "$f" || {
                printf '%sError:%s failed to create log file: %s\n' "$c_red" "$c_reset" "$f" >&2
                exit_code=1
                return 1
            }
        done

        if (( opt_xtrace )); then
            : >| "$trace_log" || {
                printf '%sError:%s failed to create trace log: %s\n' "$c_red" "$c_reset" "$trace_log" >&2
                exit_code=1
                return 1
            }
        fi

        "$mkfifo_bin" -m 600 -- "$fifo_out" "$fifo_err" || {
            printf '%sError:%s failed to create FIFOs\n' "$c_red" "$c_reset" >&2
            exit_code=1
            return 1
        }

        if ! "$cat_bin" >"$launcher_path" <<'EOF'
#!/bin/sh
set -eu

: "${DL_CHILD_INFO:?missing DL_CHILD_INFO}"
{
    printf 'pid=%s\n' "$$"
    printf 'pgid=%s\n' "$$"
} >"$DL_CHILD_INFO"

export BASH_ENV="$DL_WRAPPER_BASH_ENV"
exec "$@"
EOF
        then
            printf '%sError:%s failed to write launcher helper\n' "$c_red" "$c_reset" >&2
            exit_code=1
            return 1
        fi

        if ! "$chmod_bin" 700 -- "$launcher_path"; then
            printf '%sError:%s failed to chmod launcher helper\n' "$c_red" "$c_reset" >&2
            exit_code=1
            return 1
        fi

        if ! "$cat_bin" >"$collector_path" <<'EOF'
#!/usr/bin/env perl
use strict;
use warnings;
use IO::Select;
use Time::HiRes qw(time);

sub write_all {
    my ($fh, $buf) = @_;
    my $len = length($buf);
    my $off = 0;

    while ($off < $len) {
        my $n = syswrite($fh, $buf, $len - $off, $off);
        die "syswrite failed: $!" unless defined $n;
        $off += $n;
    }
}

sub write_terminal {
    my ($which, $buf) = @_;
    my $len = length($buf);
    my $off = 0;

    while ($off < $len) {
        my $n;
        if ($which eq 'STDOUT') {
            $n = syswrite(STDOUT, $buf, $len - $off, $off);
        } else {
            $n = syswrite(STDERR, $buf, $len - $off, $off);
        }
        die "terminal syswrite failed: $!" unless defined $n;
        $off += $n;
    }
}

my (
    $fifo_out,
    $fifo_err,
    $stdout_log,
    $stderr_log,
    $combined_log,
    $io_events_log,
    $quiet,
    $stdout_eof_flag,
    $stderr_eof_flag
) = @ARGV;

open my $out_r, '<',  $fifo_out      or die "open fifo_out: $!";
open my $err_r, '<',  $fifo_err      or die "open fifo_err: $!";
open my $out_l, '>>', $stdout_log    or die "open stdout_log: $!";
open my $err_l, '>>', $stderr_log    or die "open stderr_log: $!";
open my $cmb_l, '>>', $combined_log  or die "open combined_log: $!";
open my $evt_l, '>>', $io_events_log or die "open io_events_log: $!";

binmode STDOUT;
binmode STDERR;
binmode $out_r;
binmode $err_r;
binmode $out_l;
binmode $err_l;
binmode $cmb_l;
binmode $evt_l;

select((select(STDOUT), $| = 1)[0]);
select((select(STDERR), $| = 1)[0]);

my $sel = IO::Select->new($out_r, $err_r);
my $out_fd = fileno($out_r);
my $err_fd = fileno($err_r);

while (my @ready = $sel->can_read) {
    for my $fh (@ready) {
        my $fd = fileno($fh);
        my $n = sysread($fh, my $buf, 65536);
        die "sysread failed: $!" unless defined $n;

        if ($n == 0) {
            if ($fd == $out_fd) {
                open my $m, '>', $stdout_eof_flag or die "touch stdout_eof: $!";
                close $m or die "close stdout_eof: $!";
            } elsif ($fd == $err_fd) {
                open my $m, '>', $stderr_eof_flag or die "touch stderr_eof: $!";
                close $m or die "close stderr_eof: $!";
            }

            $sel->remove($fh);
            close $fh;
            next;
        }

        my $stream = ($fd == $out_fd) ? 'STDOUT' : 'STDERR';
        my $raw_fh = ($fd == $out_fd) ? $out_l : $err_l;

        write_all($raw_fh, $buf);
        write_all($cmb_l,  $buf);

        printf {$evt_l} "%0.9f\t%s\t%d\n", time(), $stream, $n
            or die "write io event failed: $!";

        if (!$quiet) {
            write_terminal($stream, $buf);
        }
    }
}

close $out_l or die "close stdout_log: $!";
close $err_l or die "close stderr_log: $!";
close $cmb_l or die "close combined_log: $!";
close $evt_l or die "close io_events_log: $!";
EOF
        then
            printf '%sError:%s failed to write collector helper\n' "$c_red" "$c_reset" >&2
            exit_code=1
            return 1
        fi

        if ! "$chmod_bin" 700 -- "$collector_path"; then
            printf '%sError:%s failed to chmod collector helper\n' "$c_red" "$c_reset" >&2
            exit_code=1
            return 1
        fi

        if ! "$cat_bin" >"$env_prelude" <<'EOF'
# shellcheck shell=bash

__DL_TRAP_FIRED=0
__DL_SIGNAL=""
__DL_XTRACE_ENABLED=0
__DL_PRELUDE_DEPTH="${DL_PRELUDE_DEPTH:-0}"
export DL_PRELUDE_DEPTH=$((__DL_PRELUDE_DEPTH + 1))

__dl_status_put() {
    [[ -n "${DL_CHILD_STATUS:-}" ]] || return 0
    builtin printf '%s=%s\n' "$1" "$2" >>"$DL_CHILD_STATUS" 2>/dev/null || :
}

__dl_note_event() {
    [[ -n "${DL_CHILD_EVENTS:-}" ]] || return 0

    local _event="$1" _status="$2" _sig="${3-}"
    local _cmd="${BASH_COMMAND-unknown}"
    local _src="${BASH_SOURCE[2]:-${BASH_SOURCE[1]:-${BASH_SOURCE[0]:-unknown}}}"
    local _lin="${BASH_LINENO[1]:-${BASH_LINENO[0]:-?}}"
    local -a _pipe_status=( "${PIPESTATUS[@]}" )

    {
        builtin printf 'ts=%s event=%s depth=%s pid=%s status=%s' \
            "${EPOCHREALTIME}" "${_event}" "${DL_PRELUDE_DEPTH}" "${BASHPID}" "${_status}"
        [[ -n ${_sig} ]] && builtin printf ' signal=%q' "${_sig}"
        builtin printf ' source=%q line=%s cmd=%q pipestatus=%q\n' \
            "${_src}" "${_lin}" "${_cmd}" "${_pipe_status[*]-}"
    } >>"${DL_CHILD_EVENTS}" 2>/dev/null || :
}

__dl_capture_shell_state() {
    [[ -n "${DL_SET_O_LOG:-}" ]] && set -o >"$DL_SET_O_LOG" 2>/dev/null || :
    [[ -n "${DL_SHOPT_LOG:-}" ]] && shopt -p >"$DL_SHOPT_LOG" 2>/dev/null || :
    [[ -n "${DL_TRAPS_LOG:-}" ]] && trap -p >"$DL_TRAPS_LOG" 2>/dev/null || :
}

__dl_is_secret_name() {
    local __name_upper="${1^^}"
    case "$__name_upper" in
        *PASS*|*TOKEN*|*SECRET*|*API_KEY*|*ACCESS_KEY*|*PRIVATE_KEY*|*AUTH*|*CREDENTIAL*|*COOKIE*|*SESSION*)
            return 0
            ;;
    esac
    return 1
}

__dl_note_first_error() {
    [[ -n "${DL_FIRST_ERR_LOG:-}" ]] || return 0
    [[ -s "$DL_FIRST_ERR_LOG" ]] && return 0

    local _status="$1"
    local _cmd="${BASH_COMMAND-unknown}"
    local _src="${BASH_SOURCE[2]:-${BASH_SOURCE[1]:-${BASH_SOURCE[0]:-unknown}}}"
    local _lin="${BASH_LINENO[1]:-${BASH_LINENO[0]:-?}}"
    local -a _pipe_status=( "${PIPESTATUS[@]}" )

    {
        builtin printf 'timestamp=%s\n' "${EPOCHREALTIME}"
        builtin printf 'status=%s\n' "${_status}"
        builtin printf 'trap_command=%q\n' "${_cmd}"
        builtin printf 'source=%q\n' "${_src}"
        builtin printf 'line=%s\n' "${_lin}"
        builtin printf 'pipestatus=%q\n' "${_pipe_status[*]-}"
    } >"$DL_FIRST_ERR_LOG" 2>/dev/null || :
}

__dl_capture_trap_body() {
    local _sig="$1" _raw _quoted

    _raw="$(builtin trap -p "${_sig}")" || return 0
    [[ -n ${_raw} ]] || return 0

    _quoted="${_raw#trap -- }"
    _quoted="${_quoted% ${_sig}}"

    eval "builtin printf '%s' ${_quoted}"
}

__dl_run_prior_trap() {
    local _body="$1"
    [[ -n ${_body} ]] || return 0
    eval "${_body}"
}

__dl_dump_state() {
    local _reason="$1" _status="$2" _signal="${3-}"
    [[ -n "${DL_ERROR_DUMP:-}" ]] || return 0

    local _cmd="${BASH_COMMAND-unknown}"
    local _src="${BASH_SOURCE[2]:-${BASH_SOURCE[1]:-${BASH_SOURCE[0]:-unknown}}}"
    local _lin="${BASH_LINENO[1]:-${BASH_LINENO[0]:-?}}"
    local -a _pipe_status=( "${PIPESTATUS[@]}" )

    (
        set +e +u +x
        set +o pipefail 2>/dev/null || :

        builtin printf '=== %s ===\n' "${_reason}"
        builtin printf 'timestamp=%s\n' "${EPOCHREALTIME}"
        builtin printf 'status=%s\n' "${_status}"
        [[ -n ${_signal} ]] && builtin printf 'signal=%s\n' "${_signal}"
        builtin printf 'pid=%s\nbashpid=%s\nppid=%s\n' "$$" "${BASHPID}" "${PPID}"
        builtin printf 'pwd=%q\n' "${PWD}"
        builtin printf 'command=%q\n' "${_cmd}"
        builtin printf 'source=%q\n' "${_src}"
        builtin printf 'line=%s\n' "${_lin}"
        builtin printf 'pipestatus=%q\n' "${_pipe_status[*]-}"

        builtin printf '\n--- call stack ---\n'
        local _frame=0
        while caller "${_frame}"; do
            ((_frame++))
        done || :

        builtin printf '\n--- open file descriptors ---\n'
        "${DL_LS_BIN:-ls}" -l "/proc/${BASHPID}/fd" 2>/dev/null || :

        builtin printf '\n--- variables ---\n'
        local _name
        while IFS= read -r _name; do
            if __dl_is_secret_name "$_name"; then
                builtin printf 'declare -- %s=%q\n' "$_name" '[REDACTED]'
            else
                declare -p "$_name" 2>/dev/null || :
            fi
        done < <(compgen -v | "${DL_SORT_BIN:-sort}")
        builtin printf '\n'
    ) >>"$DL_ERROR_DUMP" 2>/dev/null || :
}

if [[ -n "${DL_ORIG_BASH_ENV:-}" && -r "${DL_ORIG_BASH_ENV}" && "${DL_ORIG_BASH_ENV}" != "${DL_PRELUDE_PATH:-}" ]]; then
    . "${DL_ORIG_BASH_ENV}" || :
fi

__DL_PRIOR_ERR_TRAP="$(__dl_capture_trap_body ERR)"
__DL_PRIOR_EXIT_TRAP="$(__dl_capture_trap_body EXIT)"
__DL_PRIOR_HUP_TRAP="$(__dl_capture_trap_body HUP)"
__DL_PRIOR_INT_TRAP="$(__dl_capture_trap_body INT)"
__DL_PRIOR_QUIT_TRAP="$(__dl_capture_trap_body QUIT)"
__DL_PRIOR_TERM_TRAP="$(__dl_capture_trap_body TERM)"

