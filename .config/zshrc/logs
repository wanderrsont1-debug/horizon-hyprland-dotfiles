            builtin printf 'status=%s\n' "${_status}"
            [[ -n "${__DL_SIGNAL}" ]] && builtin printf 'signal=%s\n' "${__DL_SIGNAL}"
            [[ -n "${DL_ERROR_DUMP:-}" ]] && builtin printf 'error_dump=%q\n' "${DL_ERROR_DUMP}"
            builtin printf '\n'
        } >&2
    fi

    __dl_run_prior_trap "${__DL_PRIOR_EXIT_TRAP}" || :
    return 0
}

__dl_on_signal() {
    local _sig="$1" _code="$2" _prior=""
    __DL_SIGNAL="${_sig}"
    __dl_status_put signal "${_sig}"
    __dl_status_put signal_status "${_code}"
    __dl_note_event SIGNAL "${_code}" "${_sig}"

    if (( __DL_TRAP_FIRED == 0 )); then
        __DL_TRAP_FIRED=1
        __dl_dump_state "SIGNAL" "${_code}" "${_sig}"
        {
            builtin printf '\nSCRIPT INTERRUPTED\n'
            builtin printf 'signal=%s\nstatus=%s\n' "${_sig}" "${_code}"
            [[ -n "${DL_ERROR_DUMP:-}" ]] && builtin printf 'error_dump=%q\n' "${DL_ERROR_DUMP}"
            builtin printf '\n'
        } >&2
    fi

    case "${_sig}" in
        HUP)  _prior="${__DL_PRIOR_HUP_TRAP}" ;;
        INT)  _prior="${__DL_PRIOR_INT_TRAP}" ;;
        QUIT) _prior="${__DL_PRIOR_QUIT_TRAP}" ;;
        TERM) _prior="${__DL_PRIOR_TERM_TRAP}" ;;
    esac

    __dl_run_prior_trap "${_prior}" || :
    exit "${_code}"
}

