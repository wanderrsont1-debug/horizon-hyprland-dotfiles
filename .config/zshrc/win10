# --- Windows KVM Manager ---
# Wrapper for the python-based VM manager utility

win() {
    ${HOME}/user_scripts/dusky_vm/passthrough/50_win.py "$@"
}

# --- Auto-Completion for 'win' ---
_win_completion() {
    local -a commands
    commands=(
        'start:Start the virtual machine'
        'stop:Send a graceful shutdown signal'
        'shutdown:Send a graceful shutdown signal'
        'kill:Forcefully power off/destroy the VM'
        'destroy:Forcefully power off/destroy the VM'
        'reboot:Reboot the VM'
        'status:Display current running state'
        'list:List all defined virtual machines'
        'view:Launch looking-glass-client'
        'lg:Launch looking-glass-client'
        'show:Launch looking-glass-client'
        'launch:Start VM and wait to launch Looking Glass'
        'play:Start VM and wait to launch Looking Glass'
        'rdp:Connect to the VM via FreeRDP rescue bridge'
        'connect:Connect to the VM via FreeRDP rescue bridge'
        'edit:Edit the VM XML configuration'
        'select:Change the default preferred VM'
    )
    _describe 'action' commands
}
compdef _win_completion win
