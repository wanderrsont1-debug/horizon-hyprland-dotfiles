[Trigger]
Operation = Install
Operation = Upgrade
Operation = Remove
Type = Package
Target = *

[Action]
Description = Triggering Horizon Update Checker Service for active sessions...
When = PostTransaction
Exec = /usr/bin/bash -c 'shopt -s nullglob; for dir in /home/*/; do user="$(basename "$dir")"; uid=$(id -u "$user" 2>/dev/null) || continue; [[ -d "/run/user/$uid" ]] && runuser -u "$user" -- env XDG_RUNTIME_DIR="/run/user/$uid" systemctl --user start update_checker.service; done'
